{
  "name": "figma-code-context",
  "version": "1.5.1",
  "private": false,
  "type": "module",
  "description": "MCP server that transforms Figma API data into AI-friendly formats for LLM code generation",
  "bin": {
    "figma-code-context": "./dist/index.js"
  },
  "files": [
